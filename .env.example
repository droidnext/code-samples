# -----------------------------
# ADK Skills Demo Configuration
# -----------------------------

# Required for Gemini Developer API mode:
GOOGLE_API_KEY=your_google_ai_studio_api_key

# Optional: override model used by your agent if you parameterize it in code.
ADK_MODEL=gemini-2.5-flash

# Optional: environment label for app/runtime behavior.
ENVIRONMENT=dev

# -------------------------------------
# Optional: Vertex AI instead of API key
# -------------------------------------
# Enable Vertex AI auth flow (set to "true" to use Vertex AI):
# GOOGLE_GENAI_USE_VERTEXAI=false
#
# If using Vertex AI, set these and authenticate with gcloud/application default creds:
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
